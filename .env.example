# Copy to .env. Public vars MUST be prefixed EXPO_PUBLIC_.

# Cloudflare Pages Functions base (same /api/* the website uses).
EXPO_PUBLIC_API_BASE=https://ephix.net

# OPTIONAL — only needed for the per-title "Pulse Spark" history chart.
# This is the SAME public anon key your website already ships; read-only.
# Leave blank to simply hide the sparkline.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
